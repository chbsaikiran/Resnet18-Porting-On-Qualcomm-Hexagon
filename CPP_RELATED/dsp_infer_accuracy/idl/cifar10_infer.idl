#include "AEEStdDef.idl"

interface cifar10_infer {

    AEEResult init(in sequence<octet> model_path);

    AEEResult deinit();

    AEEResult set_param(in long param_id, in long value);

    AEEResult get_param(in long param_id, rout long value);

    AEEResult process(in sequence<octet> input_tensor,
                      rout sequence<octet> output_logits);
};
